# ─────────────────────────────────────────────────
#  Neighborhood Emergency Preparedness Hub
#  Root .gitignore — Python + Node + IDE + OS
# ─────────────────────────────────────────────────

# ── Python / Django ─────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# Django
*.sqlite3
db.sqlite3
*.log
local_settings.py
media/

# ── Node / React / Vite ────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vite build output
frontend/dist/

# ── IDE / Editor ────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS generated ────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Environment variables ───────────────────────
.env
.env.local
.env.*.local
