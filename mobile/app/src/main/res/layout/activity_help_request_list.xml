<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base"
    android:padding="20dp">

    <!-- ── Header bar ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="16sp"
            android:minWidth="48dp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.EmergencyHub.Button.Secondary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/help_requests_title"
            android:textColor="@color/accent"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ── Category filter chips ───────────────────────────────────────── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_all"
                android:checked="true"
                style="@style/Widget.Material3.Chip.Filter"
                app:chipBackgroundColor="@color/bg_surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/text_secondary"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMedical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_medical"
                style="@style/Widget.Material3.Chip.Filter"
                app:chipBackgroundColor="@color/bg_surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/text_secondary"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_food"
                style="@style/Widget.Material3.Chip.Filter"
                app:chipBackgroundColor="@color/bg_surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/text_secondary"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipShelter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_shelter"
                style="@style/Widget.Material3.Chip.Filter"
                app:chipBackgroundColor="@color/bg_surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/text_secondary"
                app:checkedIconVisible="false" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTransport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_transport"
                style="@style/Widget.Material3.Chip.Filter"
                app:chipBackgroundColor="@color/bg_surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/text_secondary"
                app:checkedIconVisible="false" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- ── Content area: RecyclerView / empty state / loading ──────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerHelpRequests"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="40sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/empty_help_requests"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/empty_help_requests_hint"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Loading spinner -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
