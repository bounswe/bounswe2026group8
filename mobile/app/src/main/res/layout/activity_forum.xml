<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_base">

    <!-- ── Fixed top section ───────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/forum_title"
                android:textColor="@color/accent"
                android:textSize="24sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNewPost"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/new_post"
                android:textSize="13sp"
                android:backgroundTint="@color/accent"
                android:textColor="@color/white"
                style="@style/Widget.EmergencyHub.Button.Primary" />

        </LinearLayout>

        <!-- Hub selector + label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txtHubLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/forum_hub_all"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/spinnerHubSelector"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="140dp"
                android:background="@drawable/sort_pill_active_bg"
                android:paddingStart="12dp"
                android:paddingEnd="8dp" />

        </LinearLayout>

        <!-- Tabs: Global / Standard / Urgent (underline style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Global tab -->
            <LinearLayout
                android:id="@+id/tabGlobal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/tabGlobalText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_global"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/forum_global"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp" />

                <View
                    android:id="@+id/tabGlobalLine"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@color/forum_global" />

            </LinearLayout>

            <!-- Standard tab -->
            <LinearLayout
                android:id="@+id/tabStandard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/tabStandardText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_standard"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_muted"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp" />

                <View
                    android:id="@+id/tabStandardLine"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@android:color/transparent" />

            </LinearLayout>

            <!-- Urgent tab -->
            <LinearLayout
                android:id="@+id/tabUrgent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/tabUrgentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_urgent"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_muted"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp" />

                <View
                    android:id="@+id/tabUrgentLine"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@android:color/transparent" />

            </LinearLayout>

        </LinearLayout>

        <!-- Subtle base line under tabs -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border"
            android:layout_marginTop="-3dp"
            android:layout_marginBottom="14dp" />

        <!-- Sort bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/sortNewest"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/sort_newest"
                android:textSize="13sp"
                android:textColor="@color/accent"
                android:background="@drawable/sort_pill_active_bg"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/sortMostLiked"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/sort_most_liked"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:background="@drawable/sort_pill_bg"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/sortHot"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/sort_hot"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:background="@drawable/sort_pill_bg" />

        </LinearLayout>

        <!-- Role filter bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/filter_all"
                android:textSize="13sp"
                android:textColor="@color/accent"
                android:background="@drawable/sort_pill_active_bg"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterExperts"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/filter_experts"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:background="@drawable/sort_pill_bg"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/filterStandardUsers"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/filter_standard_users"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:background="@drawable/sort_pill_bg" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Scrollable posts ────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPosts"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="8dp" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Empty / loading states -->
        <TextView
            android:id="@+id/txtEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/forum_loading"
            android:textColor="@color/text_muted"
            android:textSize="15sp"
            android:visibility="gone" />

    </FrameLayout>

    <!-- ── Fixed bottom bar ────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:background="@color/bg_base">

        <TextView
            android:id="@+id/linkDashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_to_dashboard"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:padding="4dp" />

    </LinearLayout>

</LinearLayout>
