<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header row: title + hub selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/txtPageTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/create_post_title"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textHubDisplay"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="140dp"
                android:maxWidth="220dp"
                android:gravity="center_vertical"
                android:background="@drawable/sort_pill_active_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:singleLine="true"
                android:ellipsize="end" />

        </LinearLayout>

        <TextView
            android:id="@+id/txtPageSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_post_subtitle_global"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Forum type selector -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/post_type_label"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/forumTypeToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@id/btnTypeGlobal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTypeGlobal"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tab_global"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTypeStandard"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tab_standard"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTypeUrgent"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tab_urgent"
                android:textColor="@color/text_primary" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Error message -->
        <TextView
            android:id="@+id/txtError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/error"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="12dp"
            android:background="@drawable/forum_type_badge_urgent"
            android:padding="12dp" />

        <!-- Post Title -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/title_label"
            style="@style/Widget.EmergencyHub.TextInput">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:textColor="@color/text_primary"
                android:maxLines="2" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Post Content -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="@string/content_label"
            style="@style/Widget.EmergencyHub.TextInput">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:textColor="@color/text_primary"
                android:minLines="6"
                android:gravity="top" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Image upload -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/images_label"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUploadImages"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/upload_from_device"
                android:textSize="13sp"
                style="@style/Widget.EmergencyHub.Button.Secondary" />

            <TextView
                android:id="@+id/txtUploadStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginStart="12dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Image URL input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:hint="@string/image_urls_one_per_line"
            style="@style/Widget.EmergencyHub.TextInput">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputImageUrls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textUri"
                android:textColor="@color/text_primary"
                android:minLines="2"
                android:gravity="top"
                android:textSize="13sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <HorizontalScrollView
            android:id="@+id/imagePreviewScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/imagePreviewContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- Create button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/create_post"
            android:textSize="16sp"
            android:backgroundTint="@color/accent"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp"
            style="@style/Widget.EmergencyHub.Button.Primary" />

        <!-- Back link -->
        <TextView
            android:id="@+id/linkBackToForum"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/back_to_forum"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:padding="8dp" />

    </LinearLayout>

</ScrollView>
