<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1C"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/card_image_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/detail_image_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:background="#161D2E" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_image_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/detail_image_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:background="#161D2E" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/detail_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Title Placeholder"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#38BDF8"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/detail_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detailed instructions will appear here..."
            android:textSize="16sp"
            android:textColor="#E5E7EB"
            android:lineSpacingExtra="6dp" />

    </LinearLayout>
</ScrollView>