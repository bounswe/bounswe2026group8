<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="14dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp"
    app:cardElevation="0dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Vote column -->
        <LinearLayout
            android:layout_width="42dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/txtUpvote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲ 0"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtDownvote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼ 0"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Content column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Repost label (Twitter-style) -->
            <TextView
                android:id="@+id/txtRepostLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"
                android:drawablePadding="4dp"
                android:visibility="gone" />

            <!-- Forum type badge -->
            <TextView
                android:id="@+id/txtForumType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginBottom="6dp" />

            <!-- Title -->
            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="6dp" />

            <!-- Image thumbnails -->
            <LinearLayout
                android:id="@+id/imageContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:visibility="gone"
                android:clipChildren="true">

                <ImageView
                    android:id="@+id/imgThumb1"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="Image 1" />

                <ImageView
                    android:id="@+id/imgThumb2"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"
                    android:contentDescription="Image 2" />

                <ImageView
                    android:id="@+id/imgThumb3"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"
                    android:contentDescription="Image 3" />

                <TextView
                    android:id="@+id/txtMoreImages"
                    android:layout_width="48dp"
                    android:layout_height="120dp"
                    android:gravity="center"
                    android:background="@color/bg_base"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Author · Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/txtAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Stats row: comments, reposts, share, repost -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtComments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtRepostCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:layout_marginStart="12dp"
                    android:visibility="gone" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/btnShare"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="Share"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:background="@drawable/sort_pill_bg" />

                <TextView
                    android:id="@+id/btnRepost"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="Repost"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:background="@drawable/sort_pill_bg"
                    android:layout_marginStart="6dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/txtReposted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reposted"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
