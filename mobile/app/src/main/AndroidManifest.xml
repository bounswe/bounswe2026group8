<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.EmergencyHub"
        android:usesCleartextTraffic="true">

        <!-- Landing screen is the launcher -->
        <activity
            android:name=".ui.LandingActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.SignUpActivity" android:exported="false" />
        <activity android:name=".ui.SignInActivity" android:exported="false" />
        <activity android:name=".ui.DashboardActivity" android:exported="false" />
        <activity android:name=".offline.ui.MapActivity" android:exported="false"/>
        <activity android:name=".offline.ui.OfflineFeaturesActivity" android:exported="false" />
        <activity android:name=".offline.ui.FirstAidActivity" android:exported="false" />
        <activity android:name=".offline.ui.EmergencyContactsActivity" android:exported="false" />
        <activity android:name=".offline.ui.FirstAidDetailActivity" android:exported="false" />
    </application>

</manifest>
